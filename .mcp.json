{
  "mcpServers": {
    "keywords-everywhere": {
      "type": "http",
      "url": "https://mcp.keywordseverywhere.com/mcp",
      "headers": {
        "Authorization": "Bearer $KEYWORDS_EVERYWHERE_API_KEY"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest", "--allow-unrestricted-file-access", "--browser", "chromium"]
    }
  }
}
